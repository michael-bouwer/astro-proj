astro-stacks/workspaces/

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store

# Stacking datasets (these are sometimes quite large, so commit the directory but not the contents)
stacking_datasets/*